import pandas as pd
import matplotlib.pyplot as plt

df = pd.read_csv("data/auditory_test_P001.csv")

# Accuracy (%)
accuracy = df["Correct"].mean() * 100

# Threshold (better estimate)
threshold = df.iloc[len(df)//2:]["Frequency_Diff"].mean()

print("Accuracy:", round(accuracy, 2), "%")
print("Threshold:", round(threshold, 2), "Hz")

# Session handling
df["session_date"] = pd.to_datetime(df["session_date"]).dt.date

session_summary = df.groupby("session_date").agg(
    Accuracy=("Correct", "mean"),
    Avg_Diff=("Frequency_Diff", "mean")
).reset_index()

session_summary["Accuracy"] *= 100

# Plot
plt.figure(figsize=(10, 5))
plt.plot(session_summary["session_date"], session_summary["Accuracy"], marker="o")

plt.xticks(rotation=45)
plt.ylabel("Accuracy (%)")
plt.xlabel("Session Date")
plt.title("Accuracy Over Time")
plt.grid(True)

plt.tight_layout()
plt.show()